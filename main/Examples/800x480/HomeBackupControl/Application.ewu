// This class implements the interface between the GUI application and the device.
$rect <1100,50,1320,90>
$output false
class DeviceClass
{
  // This property represents the state of the LED mounted on the board.
  $rect <0,50,220,90>
  property bool StartButtonState = false;

  $rect <220,50,440,90>
  onset StartButtonState
  {
    if ( pure StartButtonState == value )
      return;

    pure StartButtonState = value;

    if(StartButtonState == true && StopButtonState == true)
    {
      StopButtonState = false;
    }

    $if !$prototyper
      native ( value )
      {
        EwBspInOutSetGeneratorStartRelay( value ? 1 : 0 );
      }
    $endif

    notifyobservers ^StartButtonState;
  }

  $rect <220,0,440,40>
  inherited method Done()
  {
    $if !$prototyper
      native
      {
        /* Pump timer is owned by the autoobject and torn down with it.
           Hardware outputs are left in their last state. */
      }
    $endif

  }

  $rect <0,0,220,40>
  inherited method Init()
  {
    aArg;

    $if !$prototyper
      native
      {
        /* boot to a known-safe state: both relays released, backlight on */
        EwBspInOutSetGeneratorStartRelay( 0 );
        EwBspInOutSetBacklight( 1 );
        hbc_backlight_state = 1;
      }
    $endif

  }

  // This property represents the state of the LED mounted on the board.
  $rect <0,90,220,130>
  property bool StopButtonState = false;

  $rect <220,90,440,130>
  onset StopButtonState
  {
    if ( pure StopButtonState == value )
      return;

    pure StopButtonState = value;

    if(StartButtonState == true && StopButtonState == true)
    {
      StartButtonState = false;
    }

    $if !$prototyper
      native ( value )
      {
        EwBspInOutSetGeneratorStopRelay( value ? 1 : 0 );
      }
    $endif

    notifyobservers ^StopButtonState;
  }

  // This property represents a data value that is updated by the device driver (ADC \
  // value).
  $rect <220,190,440,230>
  property bool CityPowerState = false;

  // This method is intended to be called by the device driver to notify the GUI \
  // application about an alternation of its setting or state value.
  $rect <0,190,220,230>
  $output true
  method void UpdateCityPowerState( arg bool aNewValue )
  {
    if ( aNewValue != pure CityPowerState )
    {
      pure CityPowerState = aNewValue;
      notifyobservers ^CityPowerState;
    }
  }

  // This property represents a data value that is updated by the device driver (ADC \
  // value).
  $rect <220,230,440,270>
  property bool GeneratorBackupState = false;

  // This method is intended to be called by the device driver to notify the GUI \
  // application about an alternation of its setting or state value.
  $rect <0,230,220,270>
  $output true
  method void UpdateGeneratorBackupState( arg bool aNewValue )
  {
    if ( aNewValue != pure GeneratorBackupState )
    {
      pure GeneratorBackupState = aNewValue;
      notifyobservers ^GeneratorBackupState;
    }
  }

  // This property represents the state of the LED mounted on the board.
  $rect <0,140,220,180>
  property bool BacklightState = true;

  $rect <220,140,440,180>
  onset BacklightState
  {
    if ( pure BacklightState == value )
      return;

    pure BacklightState = value;

    $if !$prototyper
      native ( value )
      {
        hbc_backlight_state = value ? 1 : 0;
        EwBspInOutSetBacklight( hbc_backlight_state );
      }
    $endif

    /* slow the input poll while the screen is dimmed */
    Pump.Period = value ? 20 : 200;

    notifyobservers ^BacklightState;
  }

  // This method is intended to be called by the device driver to notify the GUI \
  // application about an alternation of its setting or state value.
  $rect <0,360,220,400>
  $output true
  method void ReadSettingsFromSd()
  {
    //trace "DEVICE TODO: ReadSettingsFromSd";

    $if !$prototyper
      /*
      native ( 0 )
      {
        // ...
      }
      */
      SettingsLocked.Page1SettingA = true;
      SettingsLocked.Page1SettingB = 0; 
      SettingsLocked.Page1SettingC = 4;
      SettingsLocked.Page1SettingD = 10;
      SettingsLocked.Page1SettingE = 2;
      SettingsLocked.Page1SettingF = 5;
      SettingsLocked.Page1SettingG = 3;
      SettingsLocked.Page1SettingH = 60;

      SettingsLocked.Page2SettingA = 0; // 540; // TODO RTC implementation
      SettingsLocked.Page2SettingB = 1440; // 1080; // TODO RTC implementation
      SettingsLocked.Page2SettingC = 2;
      SettingsLocked.Page2SettingD = 4;
      SettingsLocked.Page2SettingE = 2; // 15; // TODO RTC implementation
      SettingsLocked.Page2SettingF = 4; // 3; // TODO RTC implementation

      SettingsLocked.Page3SettingA = false;
      SettingsLocked.Page3SettingB = 30;
      SettingsLocked.Page3SettingC = 30;
      SettingsLocked.Page3SettingD = 36000;

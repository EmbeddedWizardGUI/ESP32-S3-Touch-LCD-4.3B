              signal BacklightOn;
              signal DialogueSettingsClose;
              signal DialogueEventsClose;
              signal StopOnPress;
            }
            else if(LogicGenericTimerA.Enabled == true)
            {
              var uint32 TimeUntilTurningOn = (((TimeBetweenAttempts + 1000) - (LogicGenericTimerA.GetCurrentTime() - LogicGenericTimerA.Time)) / 1000);

              if(LogicAttemptCounter == SettingsLocked.Page1SettingG && LogicSessionCounter == SettingsLocked.Page1SettingE)
              {
                if(NoteBottomCenterState == 7)
                {
                  NoteBottomCenter.FirstLine = "Last generator stop attemp";
                  NoteBottomCenter.SecondLine = "Entering error state if unsuccessful";
                }
              }

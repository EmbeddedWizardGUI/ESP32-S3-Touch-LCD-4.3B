  $rect <1060,361,1280,401>
  slot BatteryEventHandler
  {
    StatusBarBatteryText.String = string(Device.Battery) + "%%";

    if(Device.Battery <= 15)
    {
      BatteryAnimation.Enabled = true;
      StatusBarBatteryIcon.Color = #FF3236FF;
      StatusBarBatteryText.Color = #FF3236FF;
    }
    else
    {
      BatteryAnimation.Enabled = false;
      StatusBarBatteryIcon.Color = #000000FF;
      StatusBarBatteryText.Color = #000000FF;
    }
  }


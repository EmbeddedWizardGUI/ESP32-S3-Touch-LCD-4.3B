  $rect <1060,690,1280,730>
  slot DialogueSettingsOpen
  {
    this.Enabled = false;

    var Application::SettingsDialogue Outlet = new Application::SettingsDialogue;
    Outlet.Close = DialogueSettingsClose;
    DialogueShown = Outlet;

    PresentDialog( DialogueShown, Application::SlideBottom, null, null, null, null, null, null, null, false );

    GetRoot().BeginModal( DialogueShown );
  }

  $rect <1060,730,1280,770>
  slot DialogueSettingsClose
  {
    if(DialogueShown != null)
    {
      GetRoot().EndModal( DialogueShown );
      DismissDialog( DialogueShown, Application::SlideTop, null, null, null, null, false );
      DialogueShown = null;
    }

    GeneratorFuelLevel.MaxValue = SettingsLocked.Page3SettingD;
    GeneratorFuelLevel.CurrentValue = SettingsLocked.Page3SettingE;

    BacklightTimer.Begin = SettingsLocked.Page1SettingD * 60 * 1000;

    this.Enabled = true;
  }


  {
    HorizontalSliderC.CurrentValue = SettingsModified.Page2SettingC;
    HorizontalSliderD.CurrentValue = SettingsModified.Page2SettingD; 
    HorizontalSliderE.CurrentValue = SettingsModified.Page2SettingE;
    HorizontalSliderF.CurrentValue = SettingsModified.Page2SettingF;

    var string Hour = string(int32(SettingsModified.Page2SettingA / 60));
    if(int32(SettingsModified.Page2SettingA / 60) < 10)
    {
      Hour = "0" + Hour;  
    }

    var string Minute = string(int32(SettingsModified.Page2SettingA % 60));
    if(int32(SettingsModified.Page2SettingA % 60) < 10)
    {
      Minute = "0" + Minute;  
    }
    ValueDisplayA.Value = Hour + ":" + Minute;

    Hour = string(int32(SettingsModified.Page2SettingB / 60));
    if(int32(SettingsModified.Page2SettingB / 60) < 10)
    {
      Hour = "0" + Hour;  
    }

    Minute = string(int32(SettingsModified.Page2SettingB % 60));
    if(int32(SettingsModified.Page2SettingB % 60) < 10)
    {
      Minute = "0" + Minute;  
    }

    ValueDisplayB.Value = Hour + ":" + Minute;

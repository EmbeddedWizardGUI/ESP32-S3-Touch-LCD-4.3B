    preset RadiusBR = 0;
    preset RadiusTR = 15;
    preset RadiusTL = 15;
    preset Color = #C9C9C9FF;
  }

  $rect <20,20,160,60>
  object WidgetSet::PushButton ButtonClose
  {
    preset Bounds = <50,413,270,470>;
    preset OnRelease = OnClose;
    preset Label = "CLOSE";
    preset Appearance = WidgetSet::PushButton_Lime_Medium;
  }

  $rect <20,20,160,60>
  object WidgetSet::PushButton ButtonReset
  {
    preset Bounds = <531,413,751,470>;
    preset OnRelease = OnReset;
    preset Label = "RESET";
    preset Appearance = WidgetSet::PushButton_Lime_Medium;
  }


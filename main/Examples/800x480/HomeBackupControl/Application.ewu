      SettingsLocked.Page3SettingA = false;
      SettingsLocked.Page3SettingB = 30;
      SettingsLocked.Page3SettingC = 30;
      SettingsLocked.Page3SettingD = 36000;
      SettingsLocked.Page3SettingE = 36000;

      SettingsModified.Page1SettingA = true;
      SettingsModified.Page1SettingB = 0; 
      SettingsModified.Page1SettingC = 4;
      SettingsModified.Page1SettingD = 10;
      SettingsModified.Page1SettingE = 2;
      SettingsModified.Page1SettingF = 5;

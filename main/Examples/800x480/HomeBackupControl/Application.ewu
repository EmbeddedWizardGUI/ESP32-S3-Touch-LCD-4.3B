  var Application::DateTimePicker TimePickerB = null;

  $rect <660,390,880,430>
  slot CloseTimePickerB
  {
    if(TimePickerB != null)
    {
      var string Hour = string(TimePickerB.Hour);
      if(TimePickerB.Hour < 10)
      {
        Hour = "0" + Hour;  
      }

      var string Minute = string(TimePickerB.Minute);
      if(TimePickerB.Minute < 10)
      {
        Minute = "0" + Minute;  
      }

      var string Second = string(TimePickerB.Second);
      if(TimePickerB.Second < 10)
      {
        Second = "0" + Second;  
      }

      ValueDisplayB.Value = Hour + ":" + Minute + ":" + Second;
      this.Remove(TimePickerB);
      TimePickerB = null;
    }

    Application::Device.RtcTime = TimePickerB;

    signal UnhideControlElements;
    Focus = null;
  }


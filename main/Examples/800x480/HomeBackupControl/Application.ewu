  {
    if(NoteBottomCenterState == -2)
    {
      NoteBottomCenterState = -1;
    }
    else if(NoteBottomCenterState == 0)
    {
      NoteBottomCenterState = -2;

      NoteBottomCenterAnimate.InitialDelay = 3000;
      NoteBottomCenterAnimate.Enabled = false;
      NoteBottomCenterAnimate.Value1 = <190,444,610,504>;
      NoteBottomCenterAnimate.Value2 = <190,480,610,540>;
      NoteBottomCenterAnimate.Enabled = true;
    }
    else if(NoteBottomCenterState == 1)
    {
      NoteBottomCenterState = -2;

      NoteBottomCenterAnimate.InitialDelay = 3000;
      NoteBottomCenterAnimate.Enabled = false;
      NoteBottomCenterAnimate.Value1 = <190,444,610,504>;
      NoteBottomCenterAnimate.Value2 = <190,480,610,540>;
      NoteBottomCenterAnimate.Enabled = true;
    }
    else if(NoteBottomCenterState == 2)
    {
      NoteBottomCenterState = -2;

      NoteBottomCenterAnimate.InitialDelay = 3000;
      NoteBottomCenterAnimate.Enabled = false;
      NoteBottomCenterAnimate.Value1 = <190,444,610,504>;
      NoteBottomCenterAnimate.Value2 = <190,480,610,540>;
      NoteBottomCenterAnimate.Enabled = true;
    }
    else if(NoteBottomCenterState == 3)
    {

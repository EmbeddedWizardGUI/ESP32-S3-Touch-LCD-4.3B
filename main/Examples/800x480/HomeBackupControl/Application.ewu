  $rect <440,350,660,390>
  var Application::HourMinutePicker TimePickerA = null;

  $rect <660,350,880,390>
  slot CloseTimePickerA
  {
    if(TimePickerA != null)
    {
      SettingsModified.Page2SettingA = (TimePickerA.Hour * 60) + TimePickerA.Minute;

      var string Hour = string(TimePickerA.Hour);
      if(TimePickerA.Hour < 10)
      {
        Hour = "0" + Hour;  
      }

      var string Minute = string(TimePickerA.Minute);
      if(TimePickerA.Minute < 10)
      {
        Minute = "0" + Minute;  
      }

      ValueDisplayA.Value = Hour + ":" + Minute;
      this.Remove(TimePickerA);
      TimePickerA = null;
    }

    signal UnhideControlElements;
    Focus = null;
  }

  $rect <440,390,660,430>
  var Application::HourMinutePicker TimePickerB = null;

  $rect <660,390,880,430>
  slot CloseTimePickerB
  {
    if(TimePickerB != null)
    {
      SettingsModified.Page2SettingB = (TimePickerB.Hour * 60) + TimePickerB.Minute;

      var string Hour = string(TimePickerB.Hour);
      if(TimePickerB.Hour < 10)
      {
        Hour = "0" + Hour;  
      }

      var string Minute = string(TimePickerB.Minute);
      if(TimePickerB.Minute < 10)
      {
        Minute = "0" + Minute;  
      }

      ValueDisplayB.Value = Hour + ":" + Minute;
      this.Remove(TimePickerB);
      TimePickerB = null;
    }

    signal UnhideControlElements;
    Focus = null;
  }


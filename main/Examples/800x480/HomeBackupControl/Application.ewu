class SettingsValueDisplay : Core::Group
{
  $rect <110,40,330,80>
  inherited property Bounds = <0,0,75,33>;

  // Initialization
  note group NoteInitialization
  {
    attr Bounds = <90,0,350,100>;
  }

  // Configuration
  note group NoteConfiguration
  {
    attr Bounds = <90,110,350,330>;
  }

  $rect <110,150,330,190>
  property string Value = "";

  $rect <110,190,330,230>
  onset Value
  {
    // The value doesn't change - nothing to do.
    if ( pure Value == value )
      return;

    // Remember the property's new value.
    pure Value = value;

    ValueText.String = Value;
  }

  $rect <20,20,160,60>
  object Views::Shadow OutletShadow
  {
    preset Bounds = <2,2,73,31>;
    preset Radius = 5;
    preset BlurRadius = 1;
  }

  $rect <20,20,160,60>
  object Views::Rectangle OutletBackground
  {
    preset Bounds = <2,2,73,31>;
    preset Radius = 5;
    preset Color = #FFFFFFFF;
  }

  $rect <20,20,160,60>
  object Views::Text ValueText
  {
    preset Bounds = <2,2,69,31>;
    preset AutoSize = false;
    preset Alignment = Views::TextAlignment[AlignHorzCenter, AlignVertCenter];
    preset String = "ABC";
    preset Font = Application::FontBodyS;
    preset Color = #6B6D73FF;
  }

  $rect <110,230,330,270>
  property int32 Width;

  $rect <110,270,330,310>
  onset Width
  {
    // The value doesn't change - nothing to do.
    if ( pure Width == value )
      return;

    // Remember the property's new value.
    pure Width = value;

    OutletShadow.Bounds.x1 = 1;
    OutletShadow.Bounds.x2 = Width - 1;
    OutletBackground.Bounds.x1 = 1;
    OutletBackground.Bounds.x2 = Width - 1;
    ValueText.Bounds.x1 = 1;
    ValueText.Bounds.x2 = Width - 1;

    this.Bounds.w = Width;
  }
}


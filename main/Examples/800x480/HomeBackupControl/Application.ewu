  $rect <820,2,1040,42>
  inherited method Init()
  {
    Device.ReadSettingsFromSd();

    GeneratorFuelLevel.MinValue = -4000;
    GeneratorFuelLevel.MaxValue = SettingsLocked.Page3SettingD + 3000;
    GeneratorFuelLevel.CurrentValue = SettingsLocked.Page3SettingE;

    BacklightTimer.Begin = SettingsLocked.Page1SettingD * 60 * 1000;

    Focus = null;

    StatusBarBatteryText.String = string(Device.Battery) + "%%";

    var Core::Time CurrentTime = ClockObject.CurrentTime;
    var int32 MinuteOfDay = CurrentTime.Hour * 60 + CurrentTime.Minute;

    if(MinuteOfDay >= SettingsLocked.Page2SettingA && MinuteOfDay <= SettingsLocked.Page2SettingB)
    {
      HouseNightDayMode.Bitmap = Application::DayTime;
      LogicDayNightModeState = true;
    }
    else
    {
      HouseNightDayMode.Bitmap = Application::NightTime;
      LogicDayNightModeState = false;
    }

    signal CityPowerEventHandler;
    signal HouseStateHandling;
    signal ClockTimerOnTrigger;

    DebugCityPower.Enabled = DebugMode;
    DebugGenerator.Enabled = DebugMode;  
  }

  $rect <820,300,1040,340>
  slot StartOnPress
  {
    if(Application::Device.BacklightState == false)
      return;
                                                     
    Application::Device.StartButtonState = true;

    if(SettingsLocked.Page1SettingC != 0)
    {
      GeneratorWirelessIcon.Visible = true;
      GeneratorWirelessBackground.Visible = true; 
      GeneratorWirelessText.Visible = true;
      BacklightButton.Enabled = false;
      //QuickActionsEvents.Enabled = false; 
      QuickActionsSettings.Enabled = false;
      GeneratorRemoteStart.OnRelease = null;
      GeneratorRemoteStop.Enabled = false;
      GeneratorRemoteStart.Enabled = false;
      GeneratorRemoteStart.Label = "STARTING";
      StartTimer.Enabled = false;
      StartTimer.Period = SettingsLocked.Page1SettingC * 1000;
      StartTimer.Enabled = true;
    }
    else
    {
      GeneratorWirelessIcon.Visible = true;
      GeneratorRemoteStart.OnRelease = StartOnRelease;
    }
  }

  $rect <820,380,1040,420>
  slot StartOnRelease
  {
    if(Application::Device.BacklightState == false)
      return;

    Application::Device.StartButtonState = false;

    GeneratorWirelessIcon.Visible = false;
    GeneratorWirelessBackground.Visible = false; 
    GeneratorWirelessText.Visible = false;
    BacklightButton.Enabled = true;
    //QuickActionsEvents.Enabled = true; 
    QuickActionsSettings.Enabled = true;
    StartTimer.Enabled = false;
    GeneratorRemoteStop.Enabled = true;
    GeneratorRemoteStart.Enabled = true;
    GeneratorRemoteStart.Label = "START";

    Focus = null;
  }

  $rect <820,440,1040,480>
  slot StopOnPress
  {
    if(Application::Device.BacklightState == false)
      return;

    Application::Device.StopButtonState = true;   

    Application::Device.BacklightState = true;
    BacklightTouchHandler.Enabled = false;
    RestackBack(BacklightTouchHandler);
    RestackBack(BacklightForeground);

    if(SettingsLocked.Page1SettingC != 0)
    {
      GeneratorWirelessIcon.Visible = true;
      GeneratorWirelessBackground.Visible = true; 
      GeneratorWirelessText.Visible = true;
      BacklightButton.Enabled = false;
      //QuickActionsEvents.Enabled = false; 
      QuickActionsSettings.Enabled = false;
      GeneratorRemoteStop.OnRelease = null;
      GeneratorRemoteStart.Enabled = false;
      GeneratorRemoteStop.Enabled = false;
      GeneratorRemoteStop.Label = "STOPPING";
      StopTimer.Enabled = false;
      StopTimer.Period = SettingsLocked.Page1SettingC * 1000;
      StopTimer.Enabled = true;
    }
    else
    {
      GeneratorWirelessIcon.Visible = true;
      GeneratorRemoteStop.OnRelease = StopOnRelease;
    }     

  }

  $rect <820,520,1040,560>
  slot StopOnRelease
  {
    if(Application::Device.BacklightState == false)
      return;

    Application::Device.StopButtonState = false;

    GeneratorWirelessIcon.Visible = false;
    GeneratorWirelessBackground.Visible = false; 
    GeneratorWirelessText.Visible = false;
    BacklightButton.Enabled = true;
    //QuickActionsEvents.Enabled = true; 
    QuickActionsSettings.Enabled = true;
    StopTimer.Enabled = false;
    GeneratorRemoteStart.Enabled = true;
    GeneratorRemoteStop.Enabled = true;
    GeneratorRemoteStop.Label = "STOP";

    Focus = null;
  }

  $rect <820,580,1040,620>
  slot BacklightOn
  {
    if(Application::Device.BacklightState == true)
      return;

    Application::Device.BacklightState = true;

    BacklightTouchHandler.Enabled = false;
    RestackBack(BacklightTouchHandler);
    RestackBack(BacklightForeground);
  }

  $rect <820,620,1040,660>
  slot BacklightOff
  {
    if(Application::Device.BacklightState == false)
      return;
    if(StartTimer.Enabled == true)
      return;
    if(StopTimer.Enabled == true)
      return;
        
    Application::Device.BacklightState = false;

    BacklightTouchHandler.Enabled = true;
    RestackTop(BacklightTouchHandler);
    RestackTop(BacklightForeground);
  }

  $rect <1060,0,1280,40>
  object Core::PropertyObserver CityPowerObserver
  {
    preset OnEvent = CityPowerEventHandler;
    preset Outlet = ^Application::Device.CityPowerState;
  }

  $rect <1060,40,1280,80>
  slot CityPowerEventHandler
  {
    if(Application::Device.CityPowerState == true)
    {
      BlackoutCounter = 1;
      BlackoutIndicatorUpdate();
      BlackoutTimer.Enabled = false;

      LogicGenericTimerA.Enabled = false;
      LogicAttemptCounter = 1; 
      LogicSessionCounter = 1;
      LogicDelayState = 0;

      NoteUpLeftAnimate.Enabled = false;
      NoteUpLeftAnimate.Value1 = <0,35,325,75>;
      NoteUpLeftAnimate.Value2 = <0,-15,325,25>;
      NoteUpLeftAnimate.Enabled = true;

      if(SettingsLocked.Page3SettingA == true)
      {
        NoteUpRightAnimate.Enabled = false;
        NoteUpRightAnimate.Value1 = <475,35,800,75>;
        NoteUpRightAnimate.Value2 = <475,-15,800,25>;
        NoteUpRightAnimate.Enabled = true;
      }

      idlesignal BacklightReset;

      NoteBottomCenterState = 0;
      NoteBottomCenterAnimate.InitialDelay = 0;
      NoteBottomCenterAnimate.Enabled = false;
      NoteBottomCenterAnimate.Value1 = <190,480,610,540>;
      NoteBottomCenterAnimate.Value2 = <190,444,610,504>;
      NoteBottomCenterAnimate.Enabled = true;
      NoteBottomCenter.FirstLine = "City power on";
      NoteBottomCenter.SecondLine = "";
      NoteBottomCenter.BackgroundColor = Application::ColorCityPower;
      NoteBottomCenter.TextColor = #000000FF;

      CityPowerIndicator.Color= Application::ColorCityPower;
      CityPowerConnector1.Color= Application::ColorCityPower;
      CityPowerConnector2.Color= Application::ColorCityPower;
    }
    else
    {
      BlackoutCounter = 1;
      BlackoutIndicatorUpdate();
      BlackoutTimer.Enabled = true;

      LogicGenericTimerA.Enabled = false;
      LogicAttemptCounter = 1; 
      LogicSessionCounter = 1;
      LogicDelayState = 0;

      NoteUpLeftAnimate.Enabled = false;
      NoteUpLeftAnimate.Value1 = <0,-15,325,25>;
      NoteUpLeftAnimate.Value2 = <0,35,325,75>;
      NoteUpLeftAnimate.Enabled = true;

      if(SettingsLocked.Page3SettingA == true)
      {
        NoteUpRightAnimate.Enabled = false;
        NoteUpRightAnimate.Value1 = <475,-15,800,25>;
        NoteUpRightAnimate.Value2 = <475,35,800,75>;
        NoteUpRightAnimate.Enabled = true;
      }

      idlesignal BacklightReset;

      NoteBottomCenterState = 1;
      NoteBottomCenterAnimate.InitialDelay = 0;
      NoteBottomCenterAnimate.Enabled = false;
      NoteBottomCenterAnimate.Value1 = <190,480,610,540>;
      NoteBottomCenterAnimate.Value2 = <190,444,610,504>;
      NoteBottomCenterAnimate.Enabled = true;
      NoteBottomCenter.FirstLine = "City power off";
      NoteBottomCenter.SecondLine = "";
      NoteBottomCenter.BackgroundColor = Application::ColorWarning;
      NoteBottomCenter.TextColor = #000000FF;

      CityPowerIndicator.Color= #E3E3E3FF;
      CityPowerConnector1.Color= #E3E3E3FF;
      CityPowerConnector2.Color= #E3E3E3FF;
    }

    signal BacklightOn;
    signal HouseStateHandling;
    signal LogicTimerOnTrigger;
  }

  $rect <1060,100,1280,140>
  object Core::PropertyObserver GeneratorBackupObserver
  {
    preset OnEvent = GeneratorBackupEventHandler;
    preset Outlet = ^Application::Device.GeneratorBackupState;
  }

  $rect <1060,140,1280,180>
  slot GeneratorBackupEventHandler
  {
    if(Application::Device.GeneratorBackupState == true)
    {
      if(SettingsLocked.Page3SettingE > 0)
      {
        SettingsLocked.Page3SettingE = SettingsLocked.Page3SettingE - 45;
      }
      if(SettingsLocked.Page3SettingE < 0)
      {
        SettingsLocked.Page3SettingE = 0;
      }

      LogicGenericTimerA.Enabled = false;
      LogicAttemptCounter = 1; 
      LogicSessionCounter = 1;
      LogicDelayState = 0;

      idlesignal BacklightReset;

      NoteBottomCenterState = 2;
      NoteBottomCenterAnimate.InitialDelay = 0;
      NoteBottomCenterAnimate.Enabled = false;
      NoteBottomCenterAnimate.Value1 = <190,480,610,540>;
      NoteBottomCenterAnimate.Value2 = <190,444,610,504>;
      NoteBottomCenterAnimate.Enabled = true;
      NoteBottomCenter.FirstLine = "Generator backup on";
      NoteBottomCenter.SecondLine = "";
      NoteBottomCenter.BackgroundColor = Application::ColorGeneratorBackup;
      NoteBottomCenter.TextColor = #000000FF;

      GeneratorBackupIndicator.Color= Application::ColorGeneratorBackup;
      GeneratorBackupConnector1.Color= Application::ColorGeneratorBackup;
      GeneratorBackupConnector2.Color= Application::ColorGeneratorBackup;  
    }
    else
    {
      if(SettingsLocked.Page3SettingE > 0)
      {
        SettingsLocked.Page3SettingE = SettingsLocked.Page3SettingE - 15;
      }
      if(SettingsLocked.Page3SettingE < 0)
      {
        SettingsLocked.Page3SettingE = 0;
      }

      LogicGenericTimerA.Enabled = false;
      LogicAttemptCounter = 1; 
      LogicSessionCounter = 1;
      LogicDelayState = 0;

      idlesignal BacklightReset;

      NoteBottomCenterState = 3;
      NoteBottomCenterAnimate.InitialDelay = 0;
      NoteBottomCenterAnimate.Enabled = false;
      NoteBottomCenterAnimate.Value1 = <190,480,610,540>;
      NoteBottomCenterAnimate.Value2 = <190,444,610,504>;
      NoteBottomCenterAnimate.Enabled = true;
      NoteBottomCenter.FirstLine = "Generator backup off";
      NoteBottomCenter.SecondLine = "";
      NoteBottomCenter.BackgroundColor = #E3E3E3FF;
      NoteBottomCenter.TextColor = #000000FF;

      GeneratorBackupIndicator.Color= #E3E3E3FF;
      GeneratorBackupConnector1.Color= #E3E3E3FF;
      GeneratorBackupConnector2.Color= #E3E3E3FF;
    }

    signal BacklightOn;
    signal HouseStateHandling;
    signal LogicTimerOnTrigger;
  }


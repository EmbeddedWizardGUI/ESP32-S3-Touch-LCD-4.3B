    ValueDisplayD.Value = string(SettingsModified.Page1SettingD) + " min";
    ValueDisplayE.Value = string(SettingsModified.Page1SettingE);
    ValueDisplayF.Value = string(SettingsModified.Page1SettingF) + " min";
    ValueDisplayG.Value = string(SettingsModified.Page1SettingG);
    ValueDisplayH.Value = string(SettingsModified.Page1SettingH) + " sec";
  }

  $rect <0,710,220,750>
  slot UpdateClock
  {
    // Get the current time
    var Core::Time CurrentTime = Time.CurrentTime;

    var string Year = string(CurrentTime.Year);
    if(CurrentTime.Year < 10)
    {
      Year = "0" + Year;  
    }

    var string Month = string(CurrentTime.Month);
    if(CurrentTime.Month < 10)
    {
      Month = "0" + Month;  
    }

    var string Day = string(CurrentTime.Day);
    if(CurrentTime.Day < 10)
    {
      Day = "0" + Day;  
    }

    var string Hour = string(CurrentTime.Hour);
    if(CurrentTime.Hour < 10)
    {
      Hour = "0" + Hour;  
    }

    var string Minute = string(CurrentTime.Minute);
    if(CurrentTime.Minute < 10)
    {
      Minute = "0" + Minute;  
    }

    var string Second = string(CurrentTime.Second);
    if(CurrentTime.Second < 10)
    {
      Second = "0" + Second;  
    }

    ValueDisplayB.Value = Year + "." + Month + "." + Day + " " + Hour + ":" + Minute + ":" + Second;
  }

  $rect <0,630,220,670>
  object Core::Timer Timer
  {
    preset OnTrigger = UpdateClock;
    preset Period = 100;
    preset Begin = 0;
    preset Enabled = true;
  }


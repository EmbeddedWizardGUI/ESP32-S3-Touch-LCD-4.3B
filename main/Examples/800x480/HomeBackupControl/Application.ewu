  $rect <1540,80,1760,120>
  slot BlackoutTimerOnTrigger
  {
    BlackoutCounter = BlackoutCounter + 1;
    BlackoutIndicatorUpdate();
  }

  $rect <1540,120,1760,160>
  method void BlackoutIndicatorUpdate()
  {
    if(Application::Device.CityPowerState == false)
    {
      if(BlackoutCounter >= 0 && BlackoutCounter < 600)
      {
        NoteUpLeftText.String = "Blackout for " + string(BlackoutCounter) + " second" + ((BlackoutCounter != 1 ) ? "s" : "");
      }
      else if(BlackoutCounter >= 600 && BlackoutCounter < 7200)
      {
        NoteUpLeftText.String = "Blackout for " + string(int32(BlackoutCounter/60)) + " minute" + ((BlackoutCounter != 1 ) ? "s" : "");
      }
      else
      {
        NoteUpLeftText.String = "Blackout for " + string(int32(BlackoutCounter/3600)) + " hour" + ((BlackoutCounter != 1 ) ? "s" : "");
      }
    }
  }


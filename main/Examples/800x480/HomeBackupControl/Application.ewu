  $rect <1060,510,1280,550>
  slot HouseStateHandling
  {
    if(Application::Device.CityPowerState == false && Application::Device.GeneratorBackupState == false)
    {
      HouseAnimation.Enabled = false;
      HouseAnimation.Enabled = true;
    }
    else if(Application::Device.CityPowerState == true && Application::Device.GeneratorBackupState == false)
    {
      HouseAnimation.Enabled = false;
      HouseIndicator.ColorTL = #FFFFFFFF;
      HouseIndicator.ColorBL = #FFFFFFFF;
      HouseIndicator.ColorTR = #FFFFFFFF;
      HouseIndicator.ColorBR = #FFFFFFFF;
      HouseIndicator.Color = Application::ColorCityPower;
    }
    else if(Application::Device.CityPowerState == false && Application::Device.GeneratorBackupState == true)
    {
      HouseAnimation.Enabled = false;
      HouseIndicator.ColorTL = #FFFFFFFF;
      HouseIndicator.ColorBL = #FFFFFFFF;
      HouseIndicator.ColorTR = #FFFFFFFF;
      HouseIndicator.ColorBR = #FFFFFFFF;
      HouseIndicator.Color = Application::ColorGeneratorBackup;
    }
    else if(Application::Device.CityPowerState == true && Application::Device.GeneratorBackupState == true)
    {
      HouseAnimation.Enabled = false;
      HouseIndicator.Color = #FFFFFFFF;
      HouseIndicator.ColorTL = Application::ColorCityPower;
      HouseIndicator.ColorBL = Application::ColorCityPower;
      HouseIndicator.ColorTR = Application::ColorCityPower;
      HouseIndicator.ColorBR = Application::ColorCityPower;
    }

  }

  $rect <1060,550,1280,590>
  object Effects::ColorEffect HouseAnimation
  {
    preset OnAnimate = HouseAnimationOnAnimate;
    preset Symmetric = true;
    preset Timing = Effects::Timing.EaseIn_EaseOut;
    preset CycleDuration = 1500;
    preset Value2 = Application::ColorWarning;
    preset Value1 = #E3E3E3FF;
  }

  $rect <1060,590,1280,630>
  slot HouseAnimationOnAnimate
  {
    HouseIndicator.Color = HouseAnimation.Value;
    HouseIndicator.ColorTL = HouseAnimation.Value;
    HouseIndicator.ColorBL = HouseAnimation.Value;
    HouseIndicator.ColorTR = HouseAnimation.Value;
    HouseIndicator.ColorBR = HouseAnimation.Value;
  }


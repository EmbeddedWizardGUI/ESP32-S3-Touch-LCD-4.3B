  // This method is intended to be called by the device driver to notify the GUI \
  // application about an alternation of its setting or state value.
  $rect <220,360,440,400>
  $output true
  method void WriteSettingsToSd()
  {
    //trace "DEVICE TODO: WriteSettingsToSd";

    $if !$prototyper
      /*
      native ( 0 )
      {
        // ...
      }
      */
      SettingsLocked.Page1SettingA = SettingsModified.Page1SettingA; 
      SettingsLocked.Page1SettingB = SettingsModified.Page1SettingB; 
      SettingsLocked.Page1SettingC = SettingsModified.Page1SettingC;
      SettingsLocked.Page1SettingD = SettingsModified.Page1SettingD;
      SettingsLocked.Page1SettingE = SettingsModified.Page1SettingE;
      SettingsLocked.Page1SettingF = SettingsModified.Page1SettingF;
      SettingsLocked.Page1SettingG = SettingsModified.Page1SettingG;
      SettingsLocked.Page1SettingH = SettingsModified.Page1SettingH;
     
      SettingsLocked.Page2SettingA = SettingsModified.Page2SettingA;
      SettingsLocked.Page2SettingB = SettingsModified.Page2SettingB;
      SettingsLocked.Page2SettingC = SettingsModified.Page2SettingC;
      SettingsLocked.Page2SettingD = SettingsModified.Page2SettingD;
      SettingsLocked.Page2SettingE = SettingsModified.Page2SettingE;
      SettingsLocked.Page2SettingF = SettingsModified.Page2SettingF;
     
      SettingsLocked.Page3SettingA = SettingsModified.Page3SettingA;
      SettingsLocked.Page3SettingB = SettingsModified.Page3SettingB;
      SettingsLocked.Page3SettingC = SettingsModified.Page3SettingC;

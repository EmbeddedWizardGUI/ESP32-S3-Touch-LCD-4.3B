      SettingsLocked.Page3SettingC = SettingsModified.Page3SettingC;
      SettingsLocked.Page3SettingD = SettingsModified.Page3SettingD;
      SettingsLocked.Page3SettingE = SettingsModified.Page3SettingE;
    $endif
  }

  $rect <0,320,220,360>
  var Application::SettingsClass SettingsLocked = Application::SettingsLocked;

  $rect <220,320,440,360>
  var Application::SettingsClass SettingsModified = Application::SettingsModified;

  // This property represents a data value that is updated by the device driver (ADC \
  // value).
  $rect <220,410,440,450>
  property int32 Battery = 100;

  // This method is intended to be called by the device driver to notify the GUI \
  // application about an alternation of its setting or state value.
  $rect <0,410,220,450>
  $output true
  method void UpdateBattery( arg int32 aNewValue )
  {
    if ( aNewValue != pure Battery )
    {
      if(aNewValue <= 100 && aNewValue >= 0)
      {
        trace "DEVICE TODO: UpdateBattery";

        pure Battery = aNewValue;
        notifyobservers ^Battery;
      }
    }
  }

  // This property represents the state of the LED mounted on the board.
  $rect <0,460,220,500>
  property Application::DateTimePicker RtcTime;

  $rect <220,460,440,500>
  onset RtcTime
  {
    trace "DEVICE TODO: OnSetRtcTime";

    if ( pure RtcTime == value )
      return;

    pure RtcTime = value;

    $if !$prototyper
      /*
      native ( value )
      {
        SetBacklightState( value );
      }
      */
    $endif

    notifyobservers ^RtcTime;
  }

  // ----- BSP polling pump --------------------------------------------------
  // Fires periodically on the GUI task and pushes fresh CityPower /
  // GeneratorBackup readings into the device class. Replaces the
  // worker-thread + DeviceDriver_ProcessData polling we had in C.
  $rect <0,500,220,540>
  object Core::Timer Pump
  {
    preset OnTrigger = OnPump;
    preset Period = 20;
    preset Enabled = true;
  }

  $rect <220,500,440,540>
  slot OnPump
  {
    sender;

    /* native block: BSP-only - read the inputs, re-assert the backlight,
       stage values into Chora locals. */
    var int32 cityPower      = 0;
    var int32 generatorBackup = 0;

    $if !$prototyper
      native ( cityPower, generatorBackup )
      {
        EwBspInOutSetBacklight( hbc_backlight_state );
        cityPower        = EwBspInOutGetCityPowerState();
        generatorBackup  = EwBspInOutGetGeneratorBackupState();
      }
    $endif

    /* now back in Chora - call the device methods normally. */
    UpdateCityPowerState(       cityPower != 0 );
    UpdateGeneratorBackupState( generatorBackup != 0 );
  }

  // Directives to adapt the order of the above members according to how these members
  // where arranged when the project content was stored. In this manner the storage
  // and the expected order of the members don't depend. Merging of changes in the
  // project files is simplified.
  $member Done
  $member Init
  $member StartButtonState
  $member OnSetStartButtonState
  $member StopButtonState
  $member OnSetStopButtonState
  $member CityPowerState
  $member UpdateCityPowerState
  $member GeneratorBackupState
  $member UpdateGeneratorBackupState
  $member BacklightState
  $member OnSetBacklightState
  $member ReadSettingsFromSd
  $member WriteSettingsToSd
  $member SettingsLocked
  $member SettingsModified
  $member Battery
  $member UpdateBattery
  $member RtcTime
  $member OnSetRtcTime
  $member Pump
  $member OnPump
}


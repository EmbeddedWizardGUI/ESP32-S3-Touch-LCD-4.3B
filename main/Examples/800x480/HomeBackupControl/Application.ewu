  $rect <1060,770,1280,810>
  slot DialogueEventsOpen
  {
    this.Enabled = false;

    var Application::EventsDialogue Outlet = new Application::EventsDialogue;
    Outlet.Close = DialogueEventsClose;
    DialogueShown = Outlet;

    PresentDialog( DialogueShown, Application::SlideBottom, null, null, null, null, null, null, null, false );

    GetRoot().BeginModal( DialogueShown );
  }

  $rect <1060,810,1280,850>
  slot DialogueEventsClose
  {
    if(DialogueShown != null)
    {
      GetRoot().EndModal( DialogueShown );
      DismissDialog( DialogueShown, Application::SlideTop, null, null, null, null, false );
      DialogueShown = null;
    }

    this.Enabled = true;
  }

  $rect <1300,0,1520,40>
  object Core::KeyPressHandler KeyHandlerKeyC
  {
    preset OnPress = OnKeyHandlerKeyC;
    preset Filter = Core::KeyCode.KeyC;
  }

  $rect <1300,80,1520,120>
  object Core::KeyPressHandler KeyHandlerKeyG
  {
    preset OnPress = OnKeyHandlerKeyG;
    preset Filter = Core::KeyCode.KeyG;
  }

  $rect <1300,40,1520,80>
  slot OnKeyHandlerKeyC
  {
    if( Device.CityPowerState == false)
    {
      Device.UpdateCityPowerState(true);
    }
    else
    {
      Device.UpdateCityPowerState(false);
    }
  }

  $rect <1300,120,1520,160>
  slot OnKeyHandlerKeyG
  {
    if( Device.GeneratorBackupState == false)
    {
      Device.UpdateGeneratorBackupState(true);
    }
    else
    {
      Device.UpdateGeneratorBackupState(false);
    }
  }

  $rect <1541,260,1761,300>
  slot ClockTimerOnTrigger
  {
    // Get the current time
    var Core::Time CurrentTime = ClockObject.CurrentTime;

    var string Hour = string(CurrentTime.Hour);
    if(CurrentTime.Hour < 10)
    {
      Hour = "0" + Hour;  
    }

    var string Minute = string(CurrentTime.Minute);
    if(CurrentTime.Minute < 10)
    {
      Minute = "0" + Minute;  
    }

    var string Second = string(CurrentTime.Second);
    if(CurrentTime.Second < 10)
    {
      Second = "0" + Second;  
    }

    StatusBarClockText.String = Hour + ":" + Minute + ":" + Second;
  }

  $rect <1541,220,1761,260>
  object Core::Timer ClockTimer
  {
    preset OnTrigger = ClockTimerOnTrigger;
    preset Period = 100;
    preset Begin = 0;
    preset Enabled = true;
  }

  $rect <1541,180,1761,220>
  object Core::Time ClockObject;

  $rect <1541,360,1761,400>
  slot LogicTimerOnTrigger
  {
    // Bottom note states
    // 0 - City power on
    // 1 - City power off
    // 2 - Generator backup on
    // 3 - Generator backup off
    // 4 - Day mode enabled
    // 5 - Night mode enabled
    // 6 - Generator start attempt in N seconds \n Session 1/4 - Attempt 1/5 
    // 7 - Generator stop attempt in N seconds \n Session 1/4 - Attempt 1/5
    // 8 - Screen turns off in N seconds

    // =========================================================================
    // Wireless animation
    // =========================================================================
    if(Application::Device.StartButtonState == true)
    {
      var int32 TimeBase = SettingsLocked.Page1SettingC * 1000;
      var uint32 TimeRemoteActive = 1 + ((TimeBase - (StartTimer.GetCurrentTime() - StartTimer.Time)) / 1000);  
      GeneratorWirelessText.String =  string(TimeRemoteActive);
    }
    else if(Application::Device.StopButtonState == true)
    {
      var int32 TimeBase = SettingsLocked.Page1SettingC * 1000;
      var uint32 TimeRemoteActive = 1 + ((TimeBase - (StopTimer.GetCurrentTime() - StopTimer.Time)) / 1000);  
      GeneratorWirelessText.String =  string(TimeRemoteActive);
    }

    // =========================================================================
    // Screen off handling
    // =========================================================================
    var uint32 TimeUntilScreenOff = 1 + ((BacklightTimer.Begin - (BacklightTimer.GetCurrentTime() - BacklightTimer.Time)) / 1000);
    if(Application::Device.BacklightState == true && GeneratorErrorStartStop.Visible == false && GeneratorErrorFuelLevel.Visible == false)
    {
      if(TimeUntilScreenOff < 60)
      {
        if(NoteBottomCenterState == -1)
        {
          NoteBottomCenterState = 8;

          NoteBottomCenterAnimate.InitialDelay = 0;
          NoteBottomCenterAnimate.Enabled = false;
          NoteBottomCenterAnimate.Value1 = <190,480,610,540>;
          NoteBottomCenterAnimate.Value2 = <190,444,610,504>;
          NoteBottomCenterAnimate.Enabled = true;

          if(TimeUntilScreenOff < 600)
          {
            NoteBottomCenter.FirstLine = "Screen turns of in " + string(TimeUntilScreenOff) + " second" + ((TimeUntilScreenOff != 1 ) ? "s" : "");
          }
          else if(TimeUntilScreenOff >= 600 && TimeUntilScreenOff < 7200)
          {
            var int32 Minutes = int32(float(TimeUntilScreenOff/60.0).round);
            NoteBottomCenter.FirstLine = "Screen turns of in " + string(Minutes) + " minute" + ((TimeUntilScreenOff != 1 ) ? "s" : "");
          }
          else
          {
            var int32 Hours = int32(float(TimeUntilScreenOff/3600.0).round);
            NoteBottomCenter.FirstLine = "Screen turns of in " + string(Hours) + " hour" + ((TimeUntilScreenOff != 1 ) ? "s" : "");
          }

          NoteBottomCenter.SecondLine = "";
          NoteBottomCenter.BackgroundColor = #E3E3E3FF;
          NoteBottomCenter.TextColor = #000000FF;
        }
        else if(NoteBottomCenterState == 8)
        {
          if(TimeUntilScreenOff < 600)
          {
            NoteBottomCenter.FirstLine = "Screen turns of in " + string(TimeUntilScreenOff) + " second" + ((TimeUntilScreenOff != 1 ) ? "s" : "");
          }
          else if(TimeUntilScreenOff >= 600 && TimeUntilScreenOff < 7200)
          {
            var int32 Minutes = int32(float(TimeUntilScreenOff/60.0).round);
            NoteBottomCenter.FirstLine = "Screen turns of in " + string(Minutes) + " minute" + ((TimeUntilScreenOff != 1 ) ? "s" : "");
          }
          else
          {
            var int32 Hours = int32(float(TimeUntilScreenOff/3600.0).round);
            NoteBottomCenter.FirstLine = "Screen turns of in " + string(Hours) + " hour" + ((TimeUntilScreenOff != 1 ) ? "s" : "");
          }
        }
      }
    }
    if(GeneratorErrorStartStop.Visible == true)
    {
      idlesignal BacklightReset;
    }

    // =========================================================================
    // Start/stop logic
    // =========================================================================
    var int32 DelayOn = 0;
    var int32 DelayOff = 0;

    if(SettingsLocked.Page1SettingA == false)
    {
      // =========================================================================
      // Manager status bar note
      // =========================================================================
      StatusBarBackground.Color = Application::ColorWarning;
      StatusBarNote.String = "Automatic start/stop disabled";
    }
    else
    {
      // =========================================================================
      // Determine whether day or night mode is active
      // =========================================================================
      var Core::Time CurrentTime = ClockObject.CurrentTime;
      var int32 MinuteOfDay = CurrentTime.Hour * 60 + CurrentTime.Minute;

      if(MinuteOfDay >= SettingsLocked.Page2SettingA && MinuteOfDay < SettingsLocked.Page2SettingB)
      {
        if(LogicDayNightModeState == false)
        { 
          if(NoteBottomCenterState == -1)
          {
            NoteBottomCenterState = 4;

            NoteBottomCenterAnimate.InitialDelay = 0;
            NoteBottomCenterAnimate.Enabled = false;
            NoteBottomCenterAnimate.Value1 = <190,480,610,540>;
            NoteBottomCenterAnimate.Value2 = <190,444,610,504>;
            NoteBottomCenterAnimate.Enabled = true;
            NoteBottomCenter.FirstLine = "Day mode enabled";
            NoteBottomCenter.SecondLine = "";
            NoteBottomCenter.BackgroundColor = #E3E3E3FF;
            NoteBottomCenter.TextColor = #000000FF;
          }
        }
        LogicDayNightModeState = true;

        HouseNightDayMode.Bitmap = Application::DayTime;
        
        DelayOn = SettingsLocked.Page2SettingE;
        DelayOff = SettingsLocked.Page2SettingF;
      }
      else
      {
        if(LogicDayNightModeState == true)
        {
          if(NoteBottomCenterState == -1)
          {
            NoteBottomCenterState = 5;

            NoteBottomCenterAnimate.InitialDelay = 0;
            NoteBottomCenterAnimate.Enabled = false;
            NoteBottomCenterAnimate.Value1 = <190,480,610,540>;
            NoteBottomCenterAnimate.Value2 = <190,444,610,504>;
            NoteBottomCenterAnimate.Enabled = true;
            NoteBottomCenter.FirstLine = "Night mode enabled";
            NoteBottomCenter.SecondLine = "";
            NoteBottomCenter.BackgroundColor = #E3E3E3FF;
            NoteBottomCenter.TextColor = #000000FF;
          }
        }
        LogicDayNightModeState = false;

        HouseNightDayMode.Bitmap = Application::NightTime;

        DelayOn = SettingsLocked.Page2SettingC;
        DelayOff = SettingsLocked.Page2SettingD;
      }

      // =========================================================================
      // Regular or gasoline savings mode
      // =========================================================================
      if(SettingsLocked.Page3SettingA == true)
      {
        // =========================================================================
        // Savings mode modifications
        // =========================================================================
        StatusBarBackground.Color = Application::ColorSavingMode;
        StatusBarNote.String = "Gasoline saving mode enabled";

        if(NoteUpRightText.String != "...")
        {
          NoteUpRightBackground.Visible = true;
          NoteUpRightShadow.Visible = true;
          NoteUpRightText.Visible = true;
        }

        // =========================================================================
        // State handling
        // =========================================================================
        DelayOn = DelayOn * 60 * 1000;
        DelayOff = DelayOff * 60 * 1000;
        var int32 TimeBetweenAttempts = SettingsLocked.Page1SettingH * 1000;
        var int32 TimeBetweenSessions = SettingsLocked.Page1SettingF * 60 * 1000;
        var int32 SavingsOn = SettingsLocked.Page3SettingB * 60 * 1000;
        var int32 SavingsOff = SettingsLocked.Page3SettingC * 60 * 1000;

        // +++++++++++++++++++++++++++++++++ DEBUG +++++++++++++++++++++++++++++++++++++
        // +++++++++++++++++++++++++++++++++ DEBUG +++++++++++++++++++++++++++++++++++++
        // +++++++++++++++++++++++++++++++++ DEBUG +++++++++++++++++++++++++++++++++++++
        //TimeBetweenAttempts = 5000;
        //TimeBetweenSessions = 10000;
        //SettingsLocked.Page1SettingE = 1; // Sessions
        //SettingsLocked.Page1SettingG = 1; // Attempts
        //SavingsOn = 60000;
        //SavingsOff = 60000;
        // +++++++++++++++++++++++++++++++++ DEBUG +++++++++++++++++++++++++++++++++++++
        // +++++++++++++++++++++++++++++++++ DEBUG +++++++++++++++++++++++++++++++++++++
        // +++++++++++++++++++++++++++++++++ DEBUG +++++++++++++++++++++++++++++++++++++

        // =========================================================================
        // Savings mode logic
        // =========================================================================
        var bool TurnOnGenerator = false;
        var bool TurnOffGenerator = false;

        if(LogicSavingsModeCycle == 0)
        {
          DelayOn = 60000;
          DelayOff = 15000; 
        }
        else
        {
          DelayOn = 15000;
          DelayOff = 15000; 
        }

        if(GeneratorErrorStartStop.Visible == false)
        {
          if(Application::Device.CityPowerState == false)
          {
            if(LogicSavingsModeState == 0)
            {
              LogicGenericTimerA.Enabled = false;
              LogicDelayState = 0;
              LogicAttemptCounter = 1; 
              LogicSessionCounter = 1;

              if(LogicGenericTimerB.Enabled == false)
              {
                LogicSavingsModeState = 1;
                LogicGenericTimerB.Period = SavingsOn + 1000;
                LogicGenericTimerB.Enabled = true;
              }
            }
            else if(LogicSavingsModeState == 1)
            {
                var uint32 TimeSavingsOn = (((SavingsOn + 1000) - (LogicGenericTimerB.GetCurrentTime() - LogicGenericTimerB.Time)) / 1000);

                if(TimeSavingsOn < 600)
                {
                  NoteUpRightText.String = "Cycle " + string(LogicSavingsModeCycle + 1) + " - On for " + string(TimeSavingsOn) + " second" + ((TimeSavingsOn != 1 ) ? "s" : "");
                }
                else if(TimeSavingsOn >= 600 && TimeSavingsOn < 7200)
                {
                  var int32 Minutes = int32(float(TimeSavingsOn/60.0).round);
                  NoteUpRightText.String = "Cycle " + string(LogicSavingsModeCycle + 1) + " - On for " + string(Minutes) + " minute" + ((TimeSavingsOn != 1 ) ? "s" : "");
                }
                else
                {
                  var int32 Hours = int32(float(TimeSavingsOn/3600.0).round);
                  NoteUpRightText.String = "Cycle " + string(LogicSavingsModeCycle + 1) + " - On for " + string(Hours) + " hour" + ((TimeSavingsOn != 1 ) ? "s" : "");
                }

                if(Application::Device.GeneratorBackupState == false)
                {
                  if(Application::Device.CityPowerState == false)
                  {
                    TurnOnGenerator = true;
                  }
                }

                if(TimeSavingsOn == 0)
                {
                  LogicGenericTimerB.Enabled = false;
                  LogicSavingsModeState = 2;
                }
            }
            else if(LogicSavingsModeState == 2)
            {
              LogicGenericTimerA.Enabled = false;
              LogicDelayState = 0;
              LogicAttemptCounter = 1; 
              LogicSessionCounter = 1;

              if(LogicGenericTimerB.Enabled == false)
              {
                LogicSavingsModeState = 3;
                LogicGenericTimerB.Period = SavingsOff + 1000;
                LogicGenericTimerB.Enabled = true;
              }
            }
            else if(LogicSavingsModeState == 3)
            {
              var uint32 TimeSavingsOn = (((SavingsOff + 1000) - (LogicGenericTimerB.GetCurrentTime() - LogicGenericTimerB.Time)) / 1000);
                 
              if(TimeSavingsOn < 600)
              {
                NoteUpRightText.String = "Cycle " + string(LogicSavingsModeCycle + 1) + " - Off for " + string(TimeSavingsOn) + " second" + ((TimeSavingsOn != 1 ) ? "s" : "");
              }
              else if(TimeSavingsOn >= 600 && TimeSavingsOn < 7200)
              {
                var int32 Minutes = int32(float(LogicSavingsModeCycle/60.0).round);
                NoteUpRightText.String = "Cycle " + string(LogicSavingsModeCycle + 1) + " - Off for " + string(Minutes) + " minute" + ((TimeSavingsOn != 1 ) ? "s" : "");
              }
              else
              {
                var int32 Hours = int32(float(LogicSavingsModeCycle/3600.0).round);
                NoteUpRightText.String = "Cycle " + string(LogicSavingsModeCycle + 1) + " - Off for " + string(Hours) + " hour" + ((TimeSavingsOn != 1 ) ? "s" : "");
              }

              if(Application::Device.GeneratorBackupState == true)
              {
                TurnOffGenerator = true;
              }

              if(TimeSavingsOn == 0)
              { 
                LogicSavingsModeCycle = LogicSavingsModeCycle + 1;
                LogicGenericTimerB.Enabled = false;
                LogicSavingsModeState = 0;
              }
            }
          }
        }
        else
        {
            LogicGenericTimerB.Enabled = false;
            if(LogicSavingsModeState == 1)
            {
              LogicSavingsModeState = 0;
            }
            if(LogicSavingsModeState == 3)
            {
              LogicSavingsModeState = 2;
            }
        }

        if(Application::Device.CityPowerState == true)
        {
            if(Application::Device.GeneratorBackupState == true)
            {
              TurnOffGenerator = true;
            }
            else
            {
              LogicGenericTimerA.Enabled = false;
              LogicDelayState = 0;
              LogicAttemptCounter = 1; 
              LogicSessionCounter = 1;
            }

            LogicGenericTimerB.Enabled = false;
            LogicSavingsModeState = 0;
            LogicSavingsModeCycle = 0;
        }

        // =========================================================================
        // Action - Turn on generator
        // =========================================================================
        if(TurnOnGenerator == true)
        { 
          if(GeneratorErrorStartStop.Visible == false && GeneratorErrorFuelLevel.Visible == false)
          {
            if(NoteBottomCenterState == -1)
            {
              LogicGenericTimerA.Enabled = false;
              LogicAttemptCounter = 1; 
              LogicSessionCounter = 1;
              LogicDelayState = 0;

              NoteBottomCenterState = 6;

              NoteBottomCenterAnimate.InitialDelay = 0;
              NoteBottomCenterAnimate.Enabled = false;
              NoteBottomCenterAnimate.Value1 = <190,480,610,540>;
              NoteBottomCenterAnimate.Value2 = <190,420,610,480>;
              NoteBottomCenterAnimate.Enabled = true;
              NoteBottomCenter.BackgroundColor = Application::ColorGeneratorBackup;
              NoteBottomCenter.TextColor = #000000FF;
            }

            if(LogicDelayState == 0)
            {
              if(LogicGenericTimerA.Enabled == false)
              {
                LogicDelayState = 1;
                LogicGenericTimerA.Period = DelayOn + 1000;
                LogicGenericTimerA.Enabled = true;
              }
            }
            else if(LogicDelayState == 1)
            {
              var uint32 TimeUntilTurningOn = (((DelayOn + 1000) - (LogicGenericTimerA.GetCurrentTime() - LogicGenericTimerA.Time)) / 1000);
              if(NoteBottomCenterState == 6)
              {
                if(TimeUntilTurningOn < 600)
                {
                  NoteBottomCenter.FirstLine = "Generator start attempt in " + string(TimeUntilTurningOn) + " second" + ((TimeUntilTurningOn != 1 ) ? "s" : "");
                }
                else if(TimeUntilTurningOn >= 600 && TimeUntilTurningOn < 7200)
                {
                  var int32 Minutes = int32(float(TimeUntilTurningOn/60.0).round);
                  NoteBottomCenter.FirstLine = "Generator start attempt in " + string(Minutes) + " minute" + ((TimeUntilTurningOn != 1 ) ? "s" : "");
                }
                else
                {
                  var int32 Hours = int32(float(TimeUntilTurningOn/3600.0).round);
                  NoteBottomCenter.FirstLine = "Generator start attempt in " + string(Hours) + " hour" + ((TimeUntilTurningOn != 1 ) ? "s" : "");
                }

                NoteBottomCenter.SecondLine = "Session " + string(LogicSessionCounter) + "/" + string(SettingsLocked.Page1SettingE) + " - Attempt " + string(LogicAttemptCounter) + "/" + string(SettingsLocked.Page1SettingG);
              }

              if(TimeUntilTurningOn == 0)
              {
                LogicGenericTimerA.Enabled = false;
                LogicDelayState = 2;
              }
            }
            else if(LogicDelayState == 3)
            {
              if(LogicGenericTimerA.Enabled == false)
              {
                LogicDelayState = 4;
                LogicGenericTimerA.Period = TimeBetweenSessions + 1000;
                LogicGenericTimerA.Enabled = true;
              }
            }
            else if(LogicDelayState == 4)
            {
              var uint32 TimeUntilTurningOn = (((TimeBetweenSessions + 1000) - (LogicGenericTimerA.GetCurrentTime() - LogicGenericTimerA.Time)) / 1000);
              if(NoteBottomCenterState == 6)
              {
                if(TimeUntilTurningOn < 600)
                {
                  NoteBottomCenter.FirstLine = "Generator start attempt in " + string(TimeUntilTurningOn) + " second" + ((TimeUntilTurningOn != 1 ) ? "s" : "");
                }
                else if(TimeUntilTurningOn >= 600 && TimeUntilTurningOn < 7200)
                {
                  var int32 Minutes = int32(float(TimeUntilTurningOn/60.0).round);
                  NoteBottomCenter.FirstLine = "Generator start attempt in " + string(Minutes) + " minute" + ((TimeUntilTurningOn != 1 ) ? "s" : "");
                }
                else
                {
                  var int32 Hours = int32(float(TimeUntilTurningOn/3600.0).round);
                  NoteBottomCenter.FirstLine = "Generator start attempt in " + string(Hours) + " hour" + ((TimeUntilTurningOn != 1 ) ? "s" : "");
                }

                NoteBottomCenter.SecondLine = "Session " + string(LogicSessionCounter) + "/" + string(SettingsLocked.Page1SettingE) + " - Attempt " + string(LogicAttemptCounter) + "/" + string(SettingsLocked.Page1SettingG);
              }

              if(TimeUntilTurningOn == 0)
              {
                LogicGenericTimerA.Enabled = false;
                LogicDelayState = 5;
              }
            }
            else if(LogicDelayState == 6)
            { 
              var uint32 TimeUntilErrorState = (((TimeBetweenAttempts + 1000) - (LogicGenericTimerA.GetCurrentTime() - LogicGenericTimerA.Time)) / 1000);
              if(TimeUntilErrorState == 0)
              {
                LogicGenericTimerA.Enabled = false;
                GeneratorErrorStartStop.Bounds = <755,344,803,392>;
                GeneratorErrorStartStop.Visible = true;
                GeneratorErrorAnimation.Enabled = true;
                if(NoteBottomCenterState == 6)
                {
                  NoteBottomCenter.FirstLine = "Generator could not be started";
                  NoteBottomCenter.SecondLine = "Please check fuel level and battery";
                }
                NoteBottomCenter.BackgroundColor = Application::ColorWarning;
                GeneratorErrorState = 0;

                NoteUpRightText.String = "Cycle " + string(LogicSavingsModeCycle + 1) + " paused";
              }
              else
              {
                if(NoteBottomCenterState == 6)
                {
                  if(TimeUntilErrorState < 600)
                  {
                    NoteBottomCenter.FirstLine = "Waiting " + string(TimeUntilErrorState) + " second" + ((TimeUntilErrorState != 1 ) ? "s" : "") + " for generator";
                  }
                  else if(TimeUntilErrorState >= 600 && TimeUntilErrorState < 7200)
                  {
                    var int32 Minutes = int32(float(TimeUntilErrorState/60.0).round);
                    NoteBottomCenter.FirstLine = "Waiting " + string(Minutes) + " minute" + ((TimeUntilErrorState != 1 ) ? "s" : "") + " for generator";
                  }
                  else
                  {
                    var int32 Hours = int32(float(TimeUntilErrorState/3600.0).round);
                    NoteBottomCenter.FirstLine = "Waiting " + string(Hours) + " hour" + ((TimeUntilErrorState != 1 ) ? "s" : "") + " for generator";
                  }

                  NoteBottomCenter.SecondLine = "Entering error state if unsuccessful";
                }
              }
            }
            else if(LogicGenericTimerA.Enabled == false && LogicAttemptCounter <= SettingsLocked.Page1SettingG)
            {
              LogicGenericTimerA.Period = TimeBetweenAttempts + 1000;
              LogicGenericTimerA.Enabled = true;
              signal BacklightOn;
              signal DialogueSettingsClose;
              signal DialogueEventsClose;
              signal StartOnPress;
            }
            else if(LogicGenericTimerA.Enabled == true)
            {
              var uint32 TimeUntilTurningOn = (((TimeBetweenAttempts + 1000) - (LogicGenericTimerA.GetCurrentTime() - LogicGenericTimerA.Time)) / 1000);

              if(LogicAttemptCounter == SettingsLocked.Page1SettingG && LogicSessionCounter == SettingsLocked.Page1SettingE)
              {
                if(NoteBottomCenterState == 6)
                {
                  NoteBottomCenter.FirstLine = "Last generator start attemp";
                  NoteBottomCenter.SecondLine = "Entering error state if unsuccessful";
                }
              }
              else
              {
                if(NoteBottomCenterState == 6)
                {
                  if(TimeUntilTurningOn < 600)
                  {
                    NoteBottomCenter.FirstLine = "Generator start attempt in " + string(TimeUntilTurningOn) + " second" + ((TimeUntilTurningOn != 1 ) ? "s" : "");
                  }
                  else if(TimeUntilTurningOn >= 600 && TimeUntilTurningOn < 7200)
                  {
                    var int32 Minutes = int32(float(TimeUntilTurningOn/60.0).round);
                    NoteBottomCenter.FirstLine = "Generator start attempt in " + string(Minutes) + " minute" + ((TimeUntilTurningOn != 1 ) ? "s" : "");
                  }
                  else
                  {
                    var int32 Hours = int32(float(TimeUntilTurningOn/3600.0).round);
                    NoteBottomCenter.FirstLine = "Generator start attempt in " + string(Hours) + " hour" + ((TimeUntilTurningOn != 1 ) ? "s" : "");
                  }

                  NoteBottomCenter.SecondLine = "Session " + string(LogicSessionCounter) + "/" + string(SettingsLocked.Page1SettingE) + " - Attempt " + string(LogicAttemptCounter) + "/" + string(SettingsLocked.Page1SettingG);
                }
              }
          
              if(TimeUntilTurningOn == 0)
              {        
                LogicGenericTimerA.Enabled = false;

                if(LogicAttemptCounter == SettingsLocked.Page1SettingG)
                {
                  if(LogicSessionCounter < SettingsLocked.Page1SettingE)
                  {
                    LogicSessionCounter = LogicSessionCounter + 1;
                    LogicAttemptCounter = 1;
                    LogicDelayState = 3;
                  }
                  else
                  {
                    LogicGenericTimerA.Enabled = false;
                    LogicGenericTimerA.Period = TimeBetweenAttempts + 1000;
                    LogicGenericTimerA.Enabled = true;
                    LogicDelayState = 6;
                  }
                }
                else
                {
                  LogicAttemptCounter = LogicAttemptCounter + 1;
                }
              }
            }
          }
        }
        // =========================================================================
        // Action - Turn off generator
        // =========================================================================
        else if(TurnOffGenerator == true)
        { 
          if(GeneratorErrorStartStop.Visible == false)
          {
            if(NoteBottomCenterState == -1)
            {
              LogicGenericTimerA.Enabled = false;
              LogicAttemptCounter = 1; 
              LogicSessionCounter = 1;
              LogicDelayState = 0;

              NoteBottomCenterState = 7;

              NoteBottomCenterAnimate.InitialDelay = 0;
              NoteBottomCenterAnimate.Enabled = false;
              NoteBottomCenterAnimate.Value1 = <190,480,610,540>;
              NoteBottomCenterAnimate.Value2 = <190,420,610,480>;
              NoteBottomCenterAnimate.Enabled = true;
              NoteBottomCenter.BackgroundColor = Application::ColorGeneratorBackup;
              NoteBottomCenter.TextColor = #000000FF;
            }

            if(LogicDelayState == 0)
            {
              if(LogicGenericTimerA.Enabled == false)
              {
                LogicDelayState = 1;
                LogicGenericTimerA.Period = DelayOff + 1000;
                LogicGenericTimerA.Enabled = true;
              }
            }
            else if(LogicDelayState == 1)
            {
              if(NoteBottomCenterState == -1)
              {
                NoteBottomCenterState = 7;

                NoteBottomCenterAnimate.InitialDelay = 0;
                NoteBottomCenterAnimate.Enabled = false;
                NoteBottomCenterAnimate.Value1 = <190,480,610,540>;
                NoteBottomCenterAnimate.Value2 = <190,420,610,480>;
                NoteBottomCenterAnimate.Enabled = true;
                NoteBottomCenter.BackgroundColor = Application::ColorGeneratorBackup;
                NoteBottomCenter.TextColor = #000000FF;
              }

              var uint32 TimeUntilTurningOn = (((DelayOff + 1000) - (LogicGenericTimerA.GetCurrentTime() - LogicGenericTimerA.Time)) / 1000);
              if(NoteBottomCenterState == 7)
              {
                if(TimeUntilTurningOn < 600)
                {
                  NoteBottomCenter.FirstLine = "Generator stop attempt in " + string(TimeUntilTurningOn) + " second" + ((TimeUntilTurningOn != 1 ) ? "s" : "");
                }
                else if(TimeUntilTurningOn >= 600 && TimeUntilTurningOn < 7200)
                {
                  var int32 Minutes = int32(float(TimeUntilTurningOn/60.0).round);
                  NoteBottomCenter.FirstLine = "Generator stop attempt in " + string(Minutes) + " minute" + ((TimeUntilTurningOn != 1 ) ? "s" : "");
                }
                else
                {
                  var int32 Hours = int32(float(TimeUntilTurningOn/3600.0).round);
                  NoteBottomCenter.FirstLine = "Generator stop attempt in " + string(Hours) + " hour" + ((TimeUntilTurningOn != 1 ) ? "s" : "");
                }

                NoteBottomCenter.SecondLine = "Session " + string(LogicSessionCounter) + "/" + string(SettingsLocked.Page1SettingE) + " - Attempt " + string(LogicAttemptCounter) + "/" + string(SettingsLocked.Page1SettingG);
              }

              if(TimeUntilTurningOn == 0)
              {
                LogicGenericTimerA.Enabled = false;
                LogicDelayState = 2;
              }
            }
            else if(LogicDelayState == 3)
            {
              if(LogicGenericTimerA.Enabled == false)
              {
                LogicDelayState = 4;
                LogicGenericTimerA.Period = TimeBetweenSessions + 1000;
                LogicGenericTimerA.Enabled = true;
              }
            }
            else if(LogicDelayState == 4)
            {
              var uint32 TimeUntilTurningOn = (((TimeBetweenSessions + 1000) - (LogicGenericTimerA.GetCurrentTime() - LogicGenericTimerA.Time)) / 1000);
              if(NoteBottomCenterState == 7)
              {
                
                if(TimeUntilTurningOn < 600)
                {
                  NoteBottomCenter.FirstLine = "Generator stop attempt in " + string(TimeUntilTurningOn) + " second" + ((TimeUntilTurningOn != 1 ) ? "s" : "");
                }
                else if(TimeUntilTurningOn >= 600 && TimeUntilTurningOn < 7200)
                {
                  var int32 Minutes = int32(float(TimeUntilTurningOn/60.0).round);
                  NoteBottomCenter.FirstLine = "Generator stop attempt in " + string(Minutes) + " minute" + ((TimeUntilTurningOn != 1 ) ? "s" : "");
                }
                else
                {
                  var int32 Hours = int32(float(TimeUntilTurningOn/3600.0).round);
                  NoteBottomCenter.FirstLine = "Generator stop attempt in " + string(Hours) + " hour" + ((TimeUntilTurningOn != 1 ) ? "s" : "");
                }

                NoteBottomCenter.SecondLine = "Session " + string(LogicSessionCounter) + "/" + string(SettingsLocked.Page1SettingE) + " - Attempt " + string(LogicAttemptCounter) + "/" + string(SettingsLocked.Page1SettingG);
              }

              if(TimeUntilTurningOn == 0)
              {
                LogicGenericTimerA.Enabled = false;
                LogicDelayState = 5;
              }
            }
            else if(LogicDelayState == 6)
            { 
              if(GeneratorErrorStartStop.Visible == false && GeneratorErrorFuelLevel.Visible == false)
              {
                var uint32 TimeUntilErrorState = (((TimeBetweenAttempts + 1000) - (LogicGenericTimerA.GetCurrentTime() - LogicGenericTimerA.Time)) / 1000);
                if(TimeUntilErrorState == 0)
                {
                  LogicGenericTimerA.Enabled = false;
                  GeneratorErrorStartStop.Bounds = <755,405,803,453>;
                  GeneratorErrorStartStop.Visible = true;
                  GeneratorErrorAnimation.Enabled = true;
                  if(NoteBottomCenterState == 7)
                  {
                    NoteBottomCenter.FirstLine = "Generator could not be stopped";
                    NoteBottomCenter.SecondLine = "Please check remote control";
                  }
                  NoteBottomCenter.BackgroundColor = Application::ColorWarning;
                  GeneratorErrorState = 1;

                  NoteUpRightText.String = "Cycle " + string(LogicSavingsModeCycle + 1) + " paused";
                }
                else
                {
                  if(NoteBottomCenterState == 7)
                  {
                    if(TimeUntilErrorState < 600)
                    {
                      NoteBottomCenter.FirstLine = "Waiting " + string(TimeUntilErrorState) + " second" + ((TimeUntilErrorState != 1 ) ? "s" : "") + " for generator";
                    }
                    else if(TimeUntilErrorState >= 600 && TimeUntilErrorState < 7200)
                    {
                      var int32 Minutes = int32(float(TimeUntilErrorState/60.0).round);
                      NoteBottomCenter.FirstLine = "Waiting " + string(Minutes) + " minute" + ((TimeUntilErrorState != 1 ) ? "s" : "") + " for generator";
                    }

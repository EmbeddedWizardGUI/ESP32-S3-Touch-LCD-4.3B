  }

  $rect <20,20,160,60>
  object WidgetSet::PushButton PushButton2
  {
    preset Bounds = <700,8,775,58>;
    preset OnRelease = PageRight;
    preset Icon = Application::ArrowRight;
    preset Label = "";
    preset Appearance = WidgetSet::PushButton_Lime_Medium;
  }

  $rect <20,20,160,60>
  object WidgetSet::PushButton PushButton3
  {
    preset Bounds = <25,7,100,59>;
    preset OnRelease = PageLeft;
    preset Icon = Application::ArrowLeft;
    preset Label = "";
    preset Appearance = WidgetSet::PushButton_Lime_Medium;
  }

  $rect <0,580,220,620>
  var Core::Group Page;

  $rect <0,620,220,660>
  var int32 PageNumber = 1;

  $rect <0,660,220,700>
  slot PageLeft
  {
    if(PageNumber == 1)
    {
      PageNumber = 3;

      var Application::SettingsPage3 Outlet = new Application::SettingsPage3;
      Outlet.HideControlElements = HideControlElements;
      Outlet.UnhideControlElements = UnhideControlElements;
      Page = Outlet;

      CaptionText.String = "Settings 3/3";
      SwitchToDialog( Page, Application::SlideRight, null, null, null, Application::SlideRight, null, null, null, null, false );
    }
    else if(PageNumber == 2)
    {
      PageNumber = 1;

      var Application::SettingsPage1 Outlet = new Application::SettingsPage1;
      Outlet.HideControlElements = HideControlElements;
      Outlet.UnhideControlElements = UnhideControlElements;
      Page = Outlet;

      CaptionText.String = "Settings 1/3";
      SwitchToDialog( Page, Application::SlideRight, null, null, null, Application::SlideRight, null, null, null, null, false );
    }
    else if(PageNumber == 3)
    {
      PageNumber = 2;

      var Application::SettingsPage2 Outlet = new Application::SettingsPage2;
      Outlet.HideControlElements = HideControlElements;
      Outlet.UnhideControlElements = UnhideControlElements;
      Page = Outlet;

      CaptionText.String = "Settings 2/3";
      SwitchToDialog( Page, Application::SlideRight, null, null, null, Application::SlideRight, null, null, null, null, false );
    }
  }

  $rect <0,700,220,740>
  slot PageRight
  {
    if(PageNumber == 1)
    {
      PageNumber = 2;

      var Application::SettingsPage2 Outlet = new Application::SettingsPage2;
      Outlet.HideControlElements = HideControlElements;
      Outlet.UnhideControlElements = UnhideControlElements;
      Page = Outlet;

      CaptionText.String = "Settings 2/3";
      SwitchToDialog( Page, Application::SlideLeft, null, null, null, Application::SlideLeft, null, null, null, null, false );
    }
    else if(PageNumber == 2)
    {
      PageNumber = 3;

      var Application::SettingsPage3 Outlet = new Application::SettingsPage3;
      Outlet.HideControlElements = HideControlElements;
      Outlet.UnhideControlElements = UnhideControlElements;
      Page = Outlet;

      CaptionText.String = "Settings 3/3";
      SwitchToDialog( Page, Application::SlideLeft, null, null, null, Application::SlideLeft, null, null, null, null, false );
    }
    else if(PageNumber == 3)

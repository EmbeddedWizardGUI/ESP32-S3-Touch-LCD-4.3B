$rect <20,250,240,290>
$output false
class SettingsDialogue : Core::Group
{
  $rect <0,500,220,540>
  inherited property Bounds = <0,0,800,480>;

  $rect <0,540,220,580>
  inherited method Init()
  {
    Focus = null;

    var Application::SettingsPage1 Outlet = new Application::SettingsPage1;
    Outlet.HideControlElements = HideControlElements;
    Outlet.UnhideControlElements = UnhideControlElements;
    Page = Outlet;

    PresentDialog( Page, Application::Present, null, null, null, null, null, null, null, false );
    PageNumber = 1;
    CaptionText.String = "Settings 1/3";
  }

  $rect <20,20,160,60>
  object Views::Rectangle RemoteControlBackground
  {
    preset Bounds = <0,0,802,480>;
  }

  $rect <220,580,440,620>
  property slot Close;

  $rect <220,620,440,660>
  slot OnClose
  {
    SettingsModified.Page1SettingA = SettingsLocked.Page1SettingA; 
    SettingsModified.Page1SettingB = SettingsLocked.Page1SettingB; 
    SettingsModified.Page1SettingC = SettingsLocked.Page1SettingC;
    SettingsModified.Page1SettingD = SettingsLocked.Page1SettingD;
    SettingsModified.Page1SettingE = SettingsLocked.Page1SettingE;
    SettingsModified.Page1SettingF = SettingsLocked.Page1SettingF;
    SettingsModified.Page1SettingG = SettingsLocked.Page1SettingG;
    SettingsModified.Page1SettingH = SettingsLocked.Page1SettingH;
     
    SettingsModified.Page2SettingA = SettingsLocked.Page2SettingA;
    SettingsModified.Page2SettingB = SettingsLocked.Page2SettingB;
    SettingsModified.Page2SettingC = SettingsLocked.Page2SettingC;
    SettingsModified.Page2SettingD = SettingsLocked.Page2SettingD;
    SettingsModified.Page2SettingE = SettingsLocked.Page2SettingE;
    SettingsModified.Page2SettingF = SettingsLocked.Page2SettingF;
     
    SettingsModified.Page3SettingA = SettingsLocked.Page3SettingA;
    SettingsModified.Page3SettingB = SettingsLocked.Page3SettingB;
    SettingsModified.Page3SettingC = SettingsLocked.Page3SettingC;
    SettingsModified.Page3SettingD = SettingsLocked.Page3SettingD;
    SettingsModified.Page3SettingE = SettingsLocked.Page3SettingE;

    if(PageNumber == 1)
    {
      var Application::SettingsPage1 Outlet = (Application::SettingsPage1)Page;
      Outlet.LoadModified();
    }
    else if(PageNumber == 2)
    {
      var Application::SettingsPage2 Outlet = (Application::SettingsPage2)Page;
      Outlet.LoadModified();
    }
    else if(PageNumber == 3)
    {
      var Application::SettingsPage3 Outlet = (Application::SettingsPage3)Page;
      Outlet.LoadModified();
    }

    signal Close;
  }

  $rect <220,700,440,740>
  slot OnReset
  {
    SettingsModified.Page1SettingA = true;
    SettingsModified.Page1SettingB = 0; 
    SettingsModified.Page1SettingC = 4;
    SettingsModified.Page1SettingD = 10;
    SettingsModified.Page1SettingE = 2;
    SettingsModified.Page1SettingF = 5;
    SettingsModified.Page1SettingG = 3;
    SettingsModified.Page1SettingH = 60;

    SettingsModified.Page2SettingA = 0; // 540; // TODO RTC implementation
    SettingsModified.Page2SettingB = 1440; // 1080; // TODO RTC implementation
    SettingsModified.Page2SettingC = 2;
    SettingsModified.Page2SettingD = 4;
    SettingsModified.Page2SettingE = 2; // 15; // TODO RTC implementation
    SettingsModified.Page2SettingF = 4; // 3; // TODO RTC implementation

    SettingsModified.Page3SettingA = false;
    SettingsModified.Page3SettingB = 30;
    SettingsModified.Page3SettingC = 30;
    SettingsModified.Page3SettingD = 36000;
    SettingsModified.Page3SettingE = 36000;

    if(PageNumber == 1)
    {
      var Application::SettingsPage1 Outlet = (Application::SettingsPage1)Page;
      Outlet.LoadModified();
    }
    else if(PageNumber == 2)
    {
      var Application::SettingsPage2 Outlet = (Application::SettingsPage2)Page;
      Outlet.LoadModified();
    }
    else if(PageNumber == 3)
    {
      var Application::SettingsPage3 Outlet = (Application::SettingsPage3)Page;
      Outlet.LoadModified();
    }

    ButtonReset.Label = "DEFAULT LOADED!";
    ButtonReset.Enabled = false;
    ResetTimer.Enabled = true;
  }

  $rect <20,20,160,60>
  object Views::Shadow ButtonsShadow
  {
    preset Bounds = <25,401,775,480>;
    preset RadiusBL = 0;
    preset RadiusBR = 0;

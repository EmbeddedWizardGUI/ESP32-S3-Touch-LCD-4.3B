  var bool LogicDayNightModeState;

  $rect <1540,640,1760,680>
  var int32 LogicSavingsModeState = 0;

  $rect <1540,680,1760,720>
  var int32 LogicSavingsModeCycle = 0;

  // Timer object to drive the auto demo mode.
  $rect <1300,680,1520,720>
  object Core::Timer RuntimeTimer
  {
    preset OnTrigger = RuntimeTimerOnTrigger;
    preset Period = 1000;
    preset Enabled = true;
  }

  $rect <1300,720,1520,760>
  slot RuntimeTimerOnTrigger
  {
    if(Application::Device.GeneratorBackupState == true && SettingsLocked.Page3SettingE > 0)
    {
      SettingsLocked.Page3SettingE = SettingsLocked.Page3SettingE - 1;
    }
    if(SettingsLocked.Page3SettingE < 0)
    {
      SettingsLocked.Page3SettingE = 0;
    }

    GeneratorFuelLevel.MinValue = -4000;
    GeneratorFuelLevel.MaxValue = SettingsLocked.Page3SettingD + 3000;
    GeneratorFuelLevel.CurrentValue = SettingsLocked.Page3SettingE;

    if(SettingsLocked.Page3SettingE < int32(SettingsLocked.Page3SettingD * 0.05))
    {
      GeneratorErrorFuelLevel.Visible = true;

      if(NoteBottomCenterState != -1)
      {
        NoteBottomCenterAnimate.Enabled = false;
        NoteBottomCenterAnimate.Value1 = <190,444,610,504>;
        NoteBottomCenterAnimate.Value2 = <190,480,610,540>;
        NoteBottomCenterAnimate.Enabled = true;
      }
    }
    else
    {
      GeneratorErrorFuelLevel.Visible = false;
    }
  }

